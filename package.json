{
  "name": "valiv-cli",
  "version": "2.3.1",
  "type": "module",
  "description": "CLI tool for tracking vα-liv activities",
  "main": "dist/cli.js",
  "bin": {
    "valiv": "dist/cli.js"
  },
  "preferGlobal": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "npm run type-check && tsup src/cli.tsx --format esm --clean",
    "prepack": "npm run build",
    "dev": "tsup src/cli.tsx --format esm --watch --onSuccess \"node dist/cli.js\"",
    "test": "vitest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "release": "npm version"
  },
  "keywords": [
    "va-liv",
    "valiv",
    "imas",
    "idolmaster"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiFE-124C41/valiv-cli.git"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.0",
    "commander": "^14.0.2",
    "conf": "^15.0.2",
    "date-fns": "^4.1.0",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^18.0.4",
    "marked-terminal": "^7.3.0",
    "node-ical": "^0.26.1",
    "node-mpv": "^1.5.0",
    "open": "^11.0.0",
    "react": "^19.2.1",
    "rss-parser": "^3.13.0",
    "update-notifier": "^7.3.1",
    "youtube-transcript-plus": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.0.15"
  }
}
